# Cloudflare Pages 环境变量

# 后台管理密码（/admin 登录用，不要用弱密码）
ADMIN_CODE=your-secret-password

# Cloudflare Turnstile 人机验证（可选，不配置自动跳过）
# 前往 https://dash.cloudflare.com/ → Turnstile 创建站点获取
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Cloudflare 绑定（在 Pages Dashboard → Settings → Bindings 添加）
# DB: D1 数据库（成员/日程/留言存储）
# PHOTOS: R2 存储桶（粉丝图片存储）
