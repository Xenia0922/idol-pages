---
import site from '../data/site.json';
import { SiteSocial } from './SiteBits';

const currentPath = Astro.url?.pathname || '';

const navLinks = [
  { href: '/', label: '首页' },
  { href: '/members', label: '成员' },
  { href: '/schedule', label: '日程' },
  { href: '/gallery', label: '画廊' },
  { href: '/fans', label: '广场' },
  { href: '/tokuten', label: '特典' },
  { href: '/about', label: '关于' },
];
---

<header class="fixed top-0 left-0 right-0 z-50">
  <div class="frost">
    <div class="max-w-7xl mx-auto px-3 sm:px-4">
      <div class="flex items-center justify-between h-12 sm:h-14 md:h-16 relative">
        <a href="/" class="flex items-center gap-2 sm:gap-2.5 flex-shrink-0 group">
          <img src="/logo.png" alt={site.name} class="w-7 h-7 sm:w-8 sm:h-8 rounded-full" />
          <span class="text-base sm:text-lg md:text-xl font-extrabold tracking-tight text-gradient">{site.name}</span>
          <span class="hidden sm:inline text-[8px] sm:text-[10px] text-gray-400 tracking-widest">Fansite</span>
        </a>

        <!-- Desktop Nav — centered with absolute -->
        <nav class="hidden md:flex items-center gap-1 absolute left-1/2 -translate-x-1/2">
          {navLinks.map(link => {
            const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
            return (
              <a
                href={link.href}
                class={`nav-link px-3.5 py-2 text-sm tracking-wide ${isActive ? 'nav-active' : ''}`}
              >
                {link.label}
              </a>
            );
          })}
        </nav>

        <!-- SNS Icons + Dark Mode -->
        <div class="hidden md:flex items-center gap-3">
          <SiteSocial client:load variant="icons" initial={{ weibo: site.weibo, xiaohongshu: site.xiaohongshu, douyin: site.douyin }} />
          <span class="text-gray-300 dark:text-gray-600">|</span>
          <button id="dark-toggle" class="p-1 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors z-10 relative" aria-label="切换深色模式" aria-pressed="false" title="深色模式">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path class="sun" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
              <path class="moon hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
            </svg>
          </button>
        </div>

        <!-- Mobile: dark toggle + hamburger -->
        <div class="flex md:hidden items-center gap-0.5">
          <button id="dark-toggle-m" class="p-2.5 -mr-1 text-gray-400 z-10 relative" aria-label="切换深色模式" aria-pressed="false">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path class="sun" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
              <path class="moon hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
            </svg>
          </button>
        <button id="mobile-menu-btn" class="md:hidden p-2.5 text-gray-500" aria-label="打开主菜单" aria-expanded="false" aria-controls="mobile-menu">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path class="menu-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            <path class="menu-close hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 6l12 12M6 18L18 6"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden closed frost border-b border-pink-100/40 dark:border-white/[0.04] shadow-lg rounded-b-3xl" role="region" aria-label="主导航">
    <div class="px-4 py-2 space-y-0">
      {navLinks.map(link => {
        const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
        return (
          <a href={link.href} class={`block py-3 px-3 text-sm tracking-widest rounded-xl border-l-2 transition-colors ${isActive ? 'm-active' : 'text-gray-600 border-transparent hover:text-[var(--accent)] hover:bg-white/50 dark:hover:bg-white/5'}`}>
            {link.label}
          </a>
        );
      })}
    </div>
  </div>
</header>

<style>
  .closed { display: none !important; }
  .open {
    display: block !important;
    animation: menuSlide 0.2s ease-out forwards;
  }
  @keyframes menuSlide {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<!-- Spacer -->
<div class="h-12 sm:h-14 md:h-16"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.querySelector('.menu-open') as HTMLElement;
  const closeIcon = document.querySelector('.menu-close') as HTMLElement;

  let menuOpen = false;
  function setMenu(open: boolean) {
    menuOpen = open;
    btn?.setAttribute('aria-expanded', String(open));
    btn?.setAttribute('aria-label', open ? '关闭主菜单' : '打开主菜单');
    if (open) {
      menu?.classList.add('open');
      openIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
    } else {
      menu?.classList.remove('open');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    }
  }
  btn?.addEventListener('click', () => setMenu(!menuOpen));

  // 点击菜单内链接时先关闭菜单
  menu?.addEventListener('click', (e) => {
    const link = e.target.closest('a');
    if (link && menuOpen) setMenu(false);
  });

  // ESC 键关闭菜单
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menuOpen) setMenu(false);
  });
</script>

<script>
  (() => {
    const isDark = localStorage.getItem('dark') === '1';
    if (isDark) document.documentElement.classList.add('dark');
    updateIcons();

    function updateIcons() {
      const d = document.documentElement.classList.contains('dark');
      document.querySelectorAll('.sun').forEach(s => { if (d) s.classList.add('hidden'); else s.classList.remove('hidden'); });
      document.querySelectorAll('.moon').forEach(s => { if (d) s.classList.remove('hidden'); else s.classList.add('hidden'); });
      document.querySelectorAll('#dark-toggle, #dark-toggle-m').forEach(b => {
        b.setAttribute('aria-pressed', String(d));
        b.setAttribute('aria-label', d ? '切换为浅色模式' : '切换为深色模式');
      });
    }

    document.getElementById('dark-toggle')?.addEventListener('click', (e) => { e.preventDefault(); toggle(); });
    document.getElementById('dark-toggle-m')?.addEventListener('click', (e) => { e.preventDefault(); toggle(); });

    function toggle() {
      document.documentElement.classList.toggle('dark');
      localStorage.setItem('dark', document.documentElement.classList.contains('dark') ? '1' : '0');
      updateIcons();
    }
  })();
</script>
