---
// 成员色主题切换
// 思路：圆点自带 data-color，点击直接把自身颜色写进 --accent，不再依赖任何写死的颜色表。
// 改成员色/加新人/黄鱼鱼 都自动正确；localStorage 存 hex（fansite-accent），首屏防闪脚本读值即用。
---
<button
  id="fansite-reset"
  type="button"
  class="hidden fixed bottom-6 right-20 z-50 items-center gap-2 pl-2 pr-3 py-1.5 rounded-full text-sm font-medium shadow-lg backdrop-blur bg-white/80 dark:bg-white/10 border border-[color:var(--accent)]/30 text-gray-700 dark:text-gray-200 hover:scale-105 transition max-md:bottom-24 max-md:right-6 max-md:text-xs max-md:py-1 max-md:px-2.5 max-md:gap-1"
  title="恢复默认主题色"
>
  <span id="fansite-reset-dot" class="w-3 h-3 max-md:w-2.5 max-md:h-2.5 rounded-full" style="background: var(--accent)"></span>
  恢复默认色
</button>

<script>
  const DEFAULT = '#e83e8c';

  function applyTheme(color, member) {
    const c = (color || DEFAULT);
    document.documentElement.style.setProperty('--accent', c);
    if (c.toLowerCase() !== DEFAULT.toLowerCase()) {
      try {
        localStorage.setItem('fansite-accent', c);
        if (member) localStorage.setItem('fansite-member', member);
      } catch (e) {}
    } else {
      try {
        localStorage.removeItem('fansite-accent');
        localStorage.removeItem('fansite-member');
      } catch (e) {}
    }
    syncReset();
    window.dispatchEvent(new CustomEvent('fansite:theme', { detail: { color: c, member: member || null } }));
  }

  // 仅在已选自定义色时显示「恢复默认色」
  function syncReset() {
    const btn = document.getElementById('fansite-reset');
    if (!btn) return;
    const cur = (localStorage.getItem('fansite-accent') || '').toLowerCase();
    const active = !!cur && cur !== DEFAULT.toLowerCase();
    btn.classList.toggle('hidden', !active);
    btn.classList.toggle('flex', active);
  }

  document.addEventListener('click', (e) => {
    const dot = e.target.closest('[data-member-color]');
    if (!dot) return;
    applyTheme(dot.dataset.color || DEFAULT, dot.dataset.memberColor || null);
  });

  document.getElementById('fansite-reset')?.addEventListener('click', () => applyTheme(DEFAULT, null));

  // 跨页同步：其他标签页改了主题也跟着变
  window.addEventListener('storage', (e) => {
    if (e.key === 'fansite-accent') syncReset();
  });

  syncReset();
</script>

<style is:global>
  .text-pink-500, .text-pink-400, .text-pink-600, .text-pink-300, .text-pink-200,
  .hover\:text-pink-500, .hover\:text-pink-400, .hover\:text-pink-600 {
    color: var(--accent) !important;
  }
  .bg-pink-50 { background-color: color-mix(in srgb, var(--accent) 8%, white) !important; }
  .bg-pink-100 { background-color: color-mix(in srgb, var(--accent) 12%, white) !important; }
  .border-pink-500 { border-color: var(--accent) !important; }
  .border-pink-300 { border-color: color-mix(in srgb, var(--accent) 40%, transparent) !important; }
  .border-pink-100 { border-color: color-mix(in srgb, var(--accent) 15%, white) !important; }
  .shadow-pink-200 { box-shadow: 0 4px 12px color-mix(in srgb, var(--accent) 20%, transparent) !important; }
  .from-pink-50 { --tw-gradient-from: color-mix(in srgb, var(--accent) 5%, white) !important; }

  /* 成员色圆点：可点 + hover 放大反馈（全局统一，组件无需各自写） */
  [data-member-color] { cursor: pointer; transition: transform .15s ease; }
  [data-member-color]:hover { transform: scale(1.35); }
</style>
