---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
import TokutenContent from '../components/TokutenContent';
---

<BaseLayout title="特典">
  <section class="py-16 md:py-20 px-4 max-w-4xl mx-auto">
    <div class="text-center mb-12" data-reveal>
      <p class="section-title-en">✦</p>
      <h1 class="section-title">特典规则</h1>
      <p class="text-gray-400 mt-3">以下内容来自官方社交媒体公示</p>
    </div>

    <TokutenContent
      client:load
      initial={{
        tokuten_rules: site.tokutenRules,
        tokuten_images: [
          '/images/tokuten/tokuten_detail_0.webp',
          '/images/tokuten/tokuten_detail_1.webp',
          '/images/tokuten/tokuten_detail_2.webp',
        ],
        weibo: site.weibo,
        weiboName: site.weiboName,
      }}
    />

    <!-- 过往物贩参考 -->
    <div class="mb-8 mt-8">
      <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-4" data-reveal>✦ 过往物贩参考</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="card overflow-hidden" data-reveal style="--reveal-delay:0ms">
          <img src="/images/tokuten/hakusai_birthday_goods.webp" alt="白菜生日物贩" class="w-full" loading="lazy" />
          <div class="p-3 text-sm text-center text-gray-500 dark:text-gray-400">💛 白菜2026生日物贩</div>
        </div>
        <div class="card overflow-hidden" data-reveal style="--reveal-delay:70ms">
          <img src="/images/tokuten/hakusai_yuzi_drop.webp" alt="白菜柚子掉落切" class="w-full" loading="lazy" />
          <div class="p-3 text-sm text-center text-gray-500 dark:text-gray-400">💛💚 白菜·柚子掉落切</div>
        </div>
        <div class="card overflow-hidden" data-reveal style="--reveal-delay:140ms">
          <img src="/images/tokuten/kumo_drop.webp" alt="云团掉落切" class="w-full" loading="lazy" />
          <div class="p-3 text-sm text-center text-gray-500 dark:text-gray-400">💙 云团掉落切</div>
        </div>
      </div>
    </div>

    <div class="text-center">
      <a href={site.weibo} target="_blank" rel="noopener" class="btn-outline">关注官博 {site.weiboName} 获取最新规则</a>
    </div>
  </section>
</BaseLayout>
