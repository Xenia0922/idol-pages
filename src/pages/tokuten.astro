---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
import TokutenContent from '../components/TokutenContent';
---

<BaseLayout title="特典">
  <section class="py-16 md:py-20 px-4 max-w-4xl mx-auto">
    <div class="text-center mb-12" data-reveal>
      <p class="section-title-en">✦</p>
      <h1 class="section-title">特典规则</h1>
      <p class="text-gray-400 mt-3">以下内容来自官方社交媒体公示</p>
    </div>

    <TokutenContent
      client:load
      initial={{
        tokuten_rules: site.tokutenRules,
        tokuten_images: [
          '/images/tokuten/tokuten_detail_0.webp',
          '/images/tokuten/tokuten_detail_1.webp',
          '/images/tokuten/tokuten_detail_2.webp',
        ],
        weibo: site.weibo,
        weiboName: site.weiboName,
      }}
    />

    <!-- 过往物贩参考 -->
    <div class="mb-8 mt-8">
      <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-4" data-reveal>✦ 过往物贩参考</h2>
      <div class="card p-8 text-center text-gray-400" data-reveal>
        <p>暂无过往物贩参考</p>
        <p class="text-xs mt-2">在管理后台「特典」Tab 中添加示例图片</p>
      </div>
    </div>

    <div class="text-center">
      <a href={site.weibo} target="_blank" rel="noopener" class="btn-outline">关注官方账号获取最新规则</a>
    </div>
  </section>
</BaseLayout>
