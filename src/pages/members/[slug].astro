---
import BaseLayout from '../../layouts/BaseLayout.astro';
import membersData from '../../data/members.json';
import MemberDetail from '../../components/MemberDetail';

export function getStaticPaths() {
  return membersData.members.map(m => ({ params: { slug: m.id }, props: { member: m } }));
}

const { member } = Astro.props;
---

<BaseLayout title={member.name}>
  <section class="max-w-4xl mx-auto px-4 py-8 md:py-12">
    <a href="/members" class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-gray-600 dark:text-gray-400 mb-6">← 返回</a>

    <MemberDetail client:load slug={member.id} initial={member} />
  </section>
</BaseLayout>
