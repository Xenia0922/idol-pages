---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryGrid from '../components/GalleryGrid';
---

<BaseLayout title="画廊">
  <section class="py-16 md:py-20 px-4 max-w-6xl mx-auto">
    <div class="text-center mb-12" data-reveal>
      <p class="section-title-en">✦</p>
      <h1 class="section-title">照片画廊</h1>
      <p class="text-gray-400 mt-3">记录每一个闪耀瞬间</p>
    </div>
    <GalleryGrid client:load />
  </section>
</BaseLayout>
