{
  "name": "idol-fansite-template",
  "type": "module",
  "version": "1.0.0",
  "description": "地下偶像应援站模板",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "build:gh-pages": "node scripts/build-gh-pages.mjs",
    "preview": "astro preview",
    "build:analyze": "ANALYZE=true astro build",
    "analyze": "bash scripts/analyze-bundle.sh",
    "lint": "astro check",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy:preview": "wrangler pages deploy dist --project-name=idol-pages --branch=preview",
    "deploy:prod": "wrangler pages deploy dist --project-name=idol-pages"
  },
  "dependencies": {
    "@astrojs/react": "^4.2.4",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.3.0",
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^5.7.12",
    "marked": "^18.0.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.5",
    "astro-compress": "^2.4.1",
    "prettier": "^3.9.6",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.35.3",
    "typescript": "^5.8.3",
    "wrangler": "^4.107.0"
  }
}
